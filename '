body:not(.is-mobile) {
  .metadata-container {
    --input-height: var(--metadata-input-height);
    border-radius: var(--radius-l);
    background-color: var(--metadata-background);
    border-color: var(--metadata-border-color);
    border-style: solid;
    border-width: var(--metadata-border-width);
    padding: var(--metadata-padding);
    color: var(--text-faint);
    position: relative;
    max-width: var(--metadata-max-width);
    margin-block-end: var(--p-spacing);
    // &::before {
    //   content: "";
    //   position: absolute;
    //   inset: 0;
    //   background-image: var(--art-deco-gradient);
    //   mask-image: var(--art-deco-fan-motif);
    //   mask-size: 70px;
    //   mask-position: bottom left;
    //   opacity: 0.03;
    //   z-index: -1;
    // }
    box-shadow: var(--shadow-l);
  }

  @container metadata (width > 600px) {
    .metadata-content:not(body.is-grabbing .metadata-content:hover) {
      display: block;
      column-count: var(--properties-columns);
      column-rule: 1px dashed var(--metadata-border-color);
    }
  }

  [data-type="markdown"] {
    --metadata-border-width: 1px;
    --metadata-padding: var(--size-4-6) var(--size-4-2) var(--size-4-2) var(--size-4-2);

    .metadata-container {
      outline: 1px solid color-mix(in srgb, var(--metadata-border-color), transparent 50%);
      outline-offset: -5px;
    }

    .metadata-properties-heading .collapse-indicator {
      inset-inline-start: 0;
    }

    .metadata-properties-heading {
      --heading-padding-inline: var(--size-4-6);
      position: absolute;
      top: 0;
      transform: translateY(calc(-50% + 0.05em));
      background: linear-gradient(to right,
          transparent,
          var(--workleaves-background) var(--heading-padding-inline),
          var(--workleaves-background) calc(100% - var(--heading-padding-inline)),
          transparent 100%);
      background-size: 100% 5px;
      background-repeat: no-repeat;
      background-position: center calc(50% + 1px);
      padding-inline: var(--heading-padding-inline);
    }
  }

  .workspace>.workspace-split:not(.mod-root) [data-type="markdown"] .metadata-container {
    --metadata-padding: 0.5em 0 0 0;
    outline: none;
  }

  .workspace>.workspace-split:not(.mod-root) [data-type="markdown"] .metadata-properties-heading {
    transform: translateY(-50%);
  }
}

body {
  --button-accent-shadow-active: inset 0px 0px 0px 1px rgba(0, 0, 0, 0.15),
    inset 0px 0px 0px calc(1px + var(--button-inset-shadow-size)) rgba(0, 0, 0, 0.09);
}

// Source Code Properties
.cm-hmd-frontmatter.cm-hmd-frontmatter {
  color: var(--text-muted);

  &.cm-def,
  &.cm-meta {
    color: var(--color-yellow);
  }

  &.cm-atom {
    color: var(--color-cyan);
  }

  &.cm-keyword {
    color: var(--color-green);
  }

  &.cm-number {
    color: var(--color-red);
  }

  &.cm-string {
    color: var(--color-purple);
  }
}

/* ! 属性区加宽 & 分栏（1200px+ 三栏，1600px+ 四栏） */
/* 仅作用于中间根区域 */
.workspace-split.mod-root :is(.metadata-container, .metadata-content, .metadata-properties) {
  --properties-columns: 2;

  @container metadata (width >=1200px) and (width < 1600px) {
    --properties-columns: 3;
  }

  @container metadata (width >=1600px) {
    --properties-columns: 4;
  }

  /* 限制链接长度 */
  // .metadata-link {
  //   max-width: 100%;
  // }
}

.cm-active.HyperMD-header-1::before,
.cm-active:not(.HyperMD-header-1, .HyperMD-codeblock, .HyperMD-quote, .cm-gutterElement)::after {
  content: "";
  z-index: -2;
  inset: -2px -6px;
  position: absolute;
  background-color: oklch(from var(--color-base-100) l c h/0.5);
  border-radius: var(--radius-s);
  -electron-corner-smoothing: var(--corner-smoothing)
}
